    "audit:wiring": "node scripts/src/check-frontend-backend-wiring.mjs",
    "audit:runtime": "ALL=1 node scripts/src/runtime-audit.cjs",
    "audit:schema": "node scripts/src/audit-schema-drift.mjs",
