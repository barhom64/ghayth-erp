{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm run lint:patterns && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint:patterns": "node scripts/src/lint-patterns.mjs",
    "audit:routes": "node scripts/src/audit-routes.mjs",
    "audit:event-bus": "node scripts/src/audit-event-bus.mjs",
    "audit:api-consumption": "node scripts/src/audit-api-consumption.mjs",
    "audit:route-doubling": "node scripts/src/audit-route-doubling.mjs",
    "audit:sidebar": "node scripts/src/check-sidebar-coverage.mjs",
    "gate:nav": "node scripts/src/check-sidebar-coverage.mjs --strict",
    "audit:tabs": "node scripts/src/check-tabs-coverage.mjs",
    "gate:tabs": "node scripts/src/check-tabs-coverage.mjs --strict",
    "audit:quick-actions": "node scripts/src/check-quick-actions-coverage.mjs",
    "gate:quick-actions": "node scripts/src/check-quick-actions-coverage.mjs --strict",
    "audit:labels": "node scripts/src/check-nav-label-hygiene.mjs",
    "gate:labels": "node scripts/src/check-nav-label-hygiene.mjs --strict",
    "audit:wiring": "node scripts/src/check-frontend-backend-wiring.mjs",
    "audit:runtime": "ALL=1 node scripts/src/runtime-audit.cjs",
    "audit:schema": "node scripts/src/audit-schema-drift.mjs",
    "check:schema-drift": "node scripts/src/check-schema-drift.mjs",
    "check:dump-drift": "node scripts/src/check-dump-drift.mjs",
    "check:openapi-array-items": "node scripts/src/check-openapi-array-items.mjs",
    "check:openapi-spec": "node scripts/src/check-openapi-spec.mjs",
    "check:codegen-stale": "node scripts/src/check-codegen-stale.mjs",
    "check:live-db-drift": "node scripts/src/check-live-db-drift.mjs",
    "check:ghost-rows": "node scripts/src/check-ghost-rows.mjs",
    "check:insert-columns": "node scripts/src/check-insert-columns.mjs",
    "check:constraint-literals": "node scripts/src/check-check-constraint-literals.mjs",
    "check:required-columns": "node scripts/src/check-required-columns.mjs",
    "check:update-columns": "node scripts/src/check-update-columns.mjs",
    "check:on-conflict-targets": "node scripts/src/check-on-conflict-targets.mjs",
    "check:write-path-contracts": "node scripts/src/check-write-path-contracts.mjs",
    "check:sql-ambiguity": "node scripts/src/check-sql-ambiguity.mjs",
    "check:duplicate-migrations": "node scripts/src/check-duplicate-migrations.mjs",
    "check:button-nesting": "node scripts/src/check-button-nesting.mjs",
    "check:dup-filenames": "node scripts/src/check-dup-filenames.mjs",
    "check:audit-coverage": "node scripts/src/check-audit-coverage.mjs",
    "check:lazy-table-swallow": "node scripts/src/check-lazy-table-swallow.mjs",
    "check:postable-fallbacks": "node scripts/src/check-postable-fallbacks.mjs",
    "check:tenant-isolation": "node scripts/src/check-tenant-isolation.mjs",
    "check:tx-coverage": "node scripts/src/check-tx-coverage.mjs",
    "check:gl-swallow": "node scripts/src/check-gl-swallow.mjs",
    "audit:migrations": "node scripts/src/check-migration-policy.mjs",
    "audit:boundaries": "node scripts/src/audit-domain-boundaries.mjs",
    "audit:domain-routes": "node scripts/src/audit-domain-routes.mjs",
    "audit:stop-ship": "node scripts/src/audit-stop-ship.mjs",
    "audit:numbering-coverage": "node scripts/src/audit-numbering-coverage.mjs",
    "numbering:backfill-report": "node scripts/src/numbering-backfill-report.mjs",
    "audit:system-review": "node audit/system-review/tooling/run-all.mjs",
    "audit:print-templates": "node scripts/src/audit-print-templates.mjs",
    "guard": "bash scripts/guard.sh",
    "postinstall": "bash scripts/install-hooks.sh",
    "db:bootstrap": "bash db/bootstrap.sh",
    "db:provision-agent": "bash scripts/provision-agent-db.sh",
    "db:dump-schema": "bash db/dump-schema.sh",
    "db:dump-seed": "bash db/dump-seed.sh"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@octokit/rest": "21.1.1",
    "@replit/connectors-sdk": "^0.4.0",
    "adm-zip": "^0.5.17"
  }
}
