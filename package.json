    "check:audit-coverage": "node scripts/src/check-audit-coverage.mjs",
    "check:postable-fallbacks": "node scripts/src/check-postable-fallbacks.mjs",
    "check:tenant-isolation": "node scripts/src/check-tenant-isolation.mjs",
