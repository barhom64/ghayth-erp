    "audit:route-doubling": "node scripts/src/audit-route-doubling.mjs",
    "audit:sidebar": "node scripts/src/check-sidebar-coverage.mjs",
    "gate:nav": "node scripts/src/check-sidebar-coverage.mjs --strict",
    "audit:tabs": "node scripts/src/check-tabs-coverage.mjs",
    "gate:tabs": "node scripts/src/check-tabs-coverage.mjs --strict",
