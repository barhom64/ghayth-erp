{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm run lint:patterns && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "lint:patterns": "node scripts/src/lint-patterns.mjs",
    "audit:routes": "node scripts/src/audit-routes.mjs",
    "audit:runtime": "ALL=1 node scripts/src/runtime-audit.cjs",
    "audit:runtime:guard": "node scripts/src/audit-runtime-guard.mjs",
    "audit:schema": "node scripts/src/audit-schema-drift.mjs",
    "check:schema-drift": "node scripts/src/check-schema-drift.mjs",
    "check:ghost-rows": "node scripts/src/check-ghost-rows.mjs",
    "audit:boundaries": "node scripts/src/audit-domain-boundaries.mjs",
    "audit:domain-routes": "node scripts/src/audit-domain-routes.mjs",
    "audit:system-review": "node audit/system-review/tooling/run-all.mjs",
    "guard": "bash scripts/guard.sh",
    "postinstall": "bash scripts/install-hooks.sh",
    "db:bootstrap": "bash db/bootstrap.sh",
    "db:dump-schema": "bash db/dump-schema.sh",
    "db:dump-seed": "bash db/dump-seed.sh"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "@octokit/rest": "21.1.1",
    "@replit/connectors-sdk": "^0.4.0",
    "adm-zip": "^0.5.17"
  }
}
