# ============================================================================
# Ghayth ERP — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values you need.
# Only DATABASE_URL and JWT_SECRET are strictly required to boot the API.
# See README.md §4 for the full variable reference.
# ============================================================================

# ---- Core (API server) -----------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ghayth_erp
JWT_SECRET=replace-me-with-a-long-random-string
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
# HOSTNAME=api-server-1

# ---- Postgres pool sizing --------------------------------------------------
# Maximum number of clients the pg pool keeps open. Default is 20; raise for
# heavy concurrent traffic. The connection limit on your Postgres instance
# (max_connections) must be at least PG_POOL_MAX × number_of_app_instances.
# PG_POOL_MAX=20

# ---- Field-level encryption ------------------------------------------------
# Hex-encoded 32 bytes used to encrypt sensitive columns (e.g. national IDs,
# passport numbers, banking details) at rest. Generate with:
#   openssl rand -hex 32
# Required in production. Loss of this value makes encrypted data
# unrecoverable, so rotate it via the documented re-encryption procedure
# rather than overwriting in place.
# FIELD_ENCRYPTION_KEY=

# ---- Bootstrap admin -------------------------------------------------------
# Optional: when set, the first boot creates this admin account if no users
# exist yet. Required password complexity: ≥10 chars, upper + lower + digit
# + special char. Leaving these unset means the deterministic seed user
# (owner@local.test / Test1234!) is the only admin — fine for development,
# never for production.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# ---- Optional service accounts ---------------------------------------------
# FLEET_PASSWORD=                 # Service password for the fleet integration
# INFRA_ADMIN_EMAILS=             # Comma-separated infra-admin email allowlist

# ---- Cache / queue (optional) ----------------------------------------------
# When set, used for the per-IP rate limit store and background jobs.
# Falls back to an in-memory store when unset. Required in production
# multi-instance deployments to share rate-limit counters.
# REDIS_URL=redis://localhost:6379

# ---- CORS ------------------------------------------------------------------
# Comma-separated list of allowed origins (no trailing slash).
# Leave empty in development to disable CORS restrictions.
CORS_ORIGINS=http://localhost:5173
# CORS_ORIGIN=
# REPLIT_DEV_DOMAIN=
# REPLIT_DEPLOYMENT_URL=

# ---- Secrets vault ---------------------------------------------------------
# Hex-encoded 32 bytes. Generate with: openssl rand -hex 32
# SECRETS_ENCRYPTION_KEY=

# ---- Seed / bootstrap ------------------------------------------------------
# Set to "true" to load demo data on first boot (development only).
SEED_DEMO_DATA=false

# ---- Push notifications (optional) -----------------------------------------
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@ghayth.app

# ---- AI / behavioural intelligence (optional) ------------------------------
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# ---- Object storage (optional — document uploads) --------------------------
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=

# ---- WhatsApp Business (optional) ------------------------------------------
# WHATSAPP_VERIFY_TOKEN=ghayth_erp_verify
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_ID=
