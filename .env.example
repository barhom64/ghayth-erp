# ============================================================================
# Ghayth ERP — environment variables
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values you need.
#
# Strictly required to boot the API:
#   • DATABASE_URL          (postgres://… — the live DB)
#   • JWT_SECRET            (≥32 chars; `openssl rand -hex 32`)
#
# Additionally required when NODE_ENV=production:
#   • FIELD_ENCRYPTION_KEY  (hex 32 bytes; loss = unrecoverable PII)
#   • CORS_ORIGINS          (your frontend origin)
#   • A real ADMIN_EMAIL / ADMIN_PASSWORD (the seed user is dev-only)
#
# Full production deployment checklist: docs/DEPLOYMENT.md
# Full variable reference: README.md §4
# ============================================================================

# ---- Core (API server) -----------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ghayth_erp
JWT_SECRET=replace-me-with-a-long-random-string
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
# HOSTNAME=api-server-1

# ---- Postgres pool sizing --------------------------------------------------
# Maximum number of clients the pg pool keeps open. Default is 20; raise for
# heavy concurrent traffic. The connection limit on your Postgres instance
# (max_connections) must be at least PG_POOL_MAX × number_of_app_instances.
# PG_POOL_MAX=20

# ---- Field-level encryption ------------------------------------------------
# Hex-encoded 32 bytes used to encrypt sensitive columns (e.g. national IDs,
# passport numbers, banking details) at rest. Generate with:
#   openssl rand -hex 32
# Required in production. Loss of this value makes encrypted data
# unrecoverable, so rotate it via the documented re-encryption procedure
# rather than overwriting in place.
# FIELD_ENCRYPTION_KEY=

# ---- Bootstrap admin -------------------------------------------------------
# Optional: when set, the first boot creates this admin account if no users
# exist yet. Required password complexity: ≥10 chars, upper + lower + digit
# + special char. Leaving these unset means the deterministic seed user
# (owner@local.test / Test1234!) is the only admin — fine for development,
# never for production.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# ---- Optional service accounts ---------------------------------------------
# FLEET_PASSWORD=                 # Service password for the fleet integration
# INFRA_ADMIN_EMAILS=             # Comma-separated infra-admin email allowlist

# ---- Cache / queue (optional) ----------------------------------------------
# When set, used for the per-IP rate limit store and background jobs.
# Falls back to an in-memory store when unset. Required in production
# multi-instance deployments to share rate-limit counters.
# REDIS_URL=redis://localhost:6379

# ---- CORS ------------------------------------------------------------------
# Comma-separated list of allowed origins (no trailing slash).
# Leave empty in development to disable CORS restrictions.
CORS_ORIGINS=http://localhost:5173
# CORS_ORIGIN=
# REPLIT_DEV_DOMAIN=
# REPLIT_DEPLOYMENT_URL=

# ---- Secrets vault ---------------------------------------------------------
# Hex-encoded 32 bytes. Generate with: openssl rand -hex 32
# SECRETS_ENCRYPTION_KEY=

# ---- Seed / bootstrap ------------------------------------------------------
# Set to "true" to load demo data on first boot (development only).
SEED_DEMO_DATA=false

# ---- Push notifications (optional) -----------------------------------------
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@ghayth.app

# ---- AI / behavioural intelligence (optional) ------------------------------
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# ---- Object storage (optional — document uploads) --------------------------
# PUBLIC_OBJECT_SEARCH_PATHS=
# PRIVATE_OBJECT_DIR=

# ---- WhatsApp Business (optional) ------------------------------------------
# WHATSAPP_VERIFY_TOKEN=ghayth_erp_verify
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_ID=

# ---- ZATCA Fatoora integration (Saudi e-invoicing) ------------------------
# Production: https://gw-fatoora.zatca.gov.sa/e-invoicing/core
# Sandbox:    https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
# ZATCA_FATOORA_PROD_URL=
# ZATCA_FATOORA_SANDBOX_URL=
# Clearance request timeout (ms) — Fatoora's published SLA is < 30 s.
# ZATCA_CLEARANCE_TIMEOUT_MS=30000
# Cron retry knobs for failed Fatoora submissions.
# ZATCA_RETRY_BASE_DELAY_MS=60000
# ZATCA_RETRY_BATCH_SIZE=20
# ZATCA_RETRY_MAX_ATTEMPTS=5
# Set to "true" to allow generating CSRs from the operator UI. Production
# should rotate via the documented offline tooling instead.
# ZATCA_ALLOW_CSR_GEN=false

# ---- Mudad integration (Saudi labor ministry payroll) ---------------------
# MUDAD_PROD_URL=
# MUDAD_SANDBOX_URL=
# MUDAD_REQUEST_TIMEOUT_MS=30000

# ---- FX feed (multi-currency revaluation) ---------------------------------
# Default uses the ECB daily reference feed; override for restricted environments.
# ECB_FX_FEED_URL=https://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml
# ECB_FETCH_TIMEOUT_MS=15000
# Days a cached rate may go stale before the dashboard surfaces a warning.
# FX_RATE_STALENESS_ALERT_DAYS=3

# ---- RBAC (advanced) -------------------------------------------------------
# When set to "true", bypasses RBAC checks. EMERGENCY USE ONLY — every
# request is audit-logged with an emergency-mode flag.
# RBAC_EMERGENCY_MODE=false
# Forward RBAC denials + emergency-mode events to an external SIEM
# (Splunk HEC, Datadog logs intake, etc.). When unset, denials are only
# logged to the local logger.
# RBAC_SIEM_WEBHOOK_URL=
# RBAC_SIEM_AUTH_HEADER=Splunk\ <hec-token>     # full Authorization header value

# ---- Event-log persistence -------------------------------------------------
# By default only events marked `critical: true` in the event catalog persist
# to `event_logs` — non-critical events are emitted in-memory only so the
# table doesn't bloat. Set this to "true" to persist EVERY emitted event
# (full audit trail; recommended in production where event_logs ≈ audit
# requirement; expect ~10× growth on this table).
# PERSIST_ALL_EVENTS=false

# ---- Redis (advanced — most setups use REDIS_URL above) -------------------
# Standalone host/port form, used when REDIS_URL isn't suitable.
# REDIS_HOST=localhost
# REDIS_PORT=6379

# ---- Health / readiness probes --------------------------------------------
# /readyz caches its dependency-probe result for this many milliseconds so a
# burst of orchestrator probes never stampedes the database.
# READYZ_CACHE_MS=5000
# Hard per-dependency probe timeout for /readyz (ms). A probe exceeding this
# is classified `dependency-failed` instead of hanging the readiness check.
# HEALTH_PROBE_TIMEOUT_MS=2000
