# Ghayth ERP — Production environment example for Hostinger VPS
# Copy to .env on the server only. Never commit real secrets.

# ---------------------------------------------------------------------------
# Required domain/origin
# ---------------------------------------------------------------------------
APP_DOMAIN=example.com
CORS_ORIGINS=https://example.com

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=ghayth_erp
POSTGRES_USER=ghayth
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL

# ---------------------------------------------------------------------------
# API security
# Generate each secret on the server:
#   openssl rand -hex 32
# ---------------------------------------------------------------------------
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
FIELD_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL
SECRETS_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

NODE_ENV=production
LOG_LEVEL=info
PERSIST_ALL_EVENTS=true

# ---------------------------------------------------------------------------
# First admin account
# Use a real email and strong password. Change after first login.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_10_PLUS_CHARS

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=/var/lib/ghayth/storage

# ---------------------------------------------------------------------------
# Optional integrations
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=

# Always false in production unless intentionally doing a staging demo.
SEED_DEMO_DATA=false
