{
  "name": "ghayth-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "expo export -p web --output-dir dist-web && cp -r public/* dist-web/",
    "export:web:offline": "EXPO_NO_TELEMETRY=1 EXPO_OFFLINE=1 expo export -p web --output-dir dist-web && cp -r public/* dist-web/"
  },
  "dependencies": {
    "@expo-google-fonts/ibm-plex-sans-arabic": "^0.2.0",
    "@expo/metro-runtime": "^56.0.15",
    "@expo/vector-icons": "^14.1.0",
    "@tanstack/react-query": "^5.90.21",
    "@workspace/tokens": "workspace:*",
    "@workspace/ui-native": "workspace:*",
    "babel-plugin-react-compiler": "^1.0.0",
    "expo": "~53.0.0",
    "expo-blur": "~14.1.0",
    "expo-constants": "^56.0.18",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.0",
    "expo-image": "~2.3.0",
    "expo-linear-gradient": "~14.1.0",
    "expo-linking": "^56.0.14",
    "expo-modules-core": "^56.0.17",
    "expo-router": "~5.1.0",
    "expo-secure-store": "~14.2.0",
    "expo-splash-screen": "~0.30.0",
    "expo-status-bar": "~2.2.3",
    "expo-web-browser": "~14.1.0",
    "react": "19.1.0",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "4.14.1",
    "react-native-screens": "~4.10.0",
    "react-native-web": "~0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "^19.0.0",
    "typescript": "~5.8.3"
  }
}
