{
  "expo": {
    "name": "غيث ERP — تطبيق الجوال",
    "slug": "ghayth-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ghayth-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "sa.door.ghayth",
      "infoPlist": {
        "NSCameraUsageDescription": "يحتاج التطبيق إلى الكاميرا لتصوير الحضور والمستندات",
        "NSLocationWhenInUseUsageDescription": "يحتاج التطبيق إلى موقعك لتسجيل الحضور الميداني",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "يحتاج التطبيق إلى موقعك لتسجيل الحضور الميداني",
        "NSPhotoLibraryUsageDescription": "يحتاج التطبيق إلى معرض الصور لرفع المستندات"
      }
    },
    "android": {
      "package": "sa.door.ghayth",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#F97316"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "output": "single",
      "themeColor": "#F97316",
      "backgroundColor": "#ffffff",
      "shortName": "غيث ERP",
      "lang": "ar",
      "dir": "rtl"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://hr.door.sa"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ghayth-erp-mobile"
      }
    }
  }
}
