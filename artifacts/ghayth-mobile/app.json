{
  "expo": {
    "name": "غيث ERP — تطبيق الجوال",
    "slug": "ghayth-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ghayth-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "sa.door.ghayth"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "output": "single",
      "themeColor": "#F97316",
      "backgroundColor": "#ffffff",
      "shortName": "غيث ERP",
      "lang": "ar",
      "dir": "rtl"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://hr.door.sa"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
